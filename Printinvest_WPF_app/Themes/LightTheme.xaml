<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="NavBackgroundColor">#FFF8FAFC</Color>
    <Color x:Key="ContentBackgroundColor">#FFF3F6FA</Color>

    <SolidColorBrush x:Key="NavBackgroundBrush" Color="{StaticResource NavBackgroundColor}"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFF8FAFC"/>

    <SolidColorBrush x:Key="NavTextBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="NavItemHoverBrush" Color="#FFE8F0FB" />
    <SolidColorBrush x:Key="NavItemPressedBrush" Color="#FFDCE8F8" />

    <SolidColorBrush x:Key="TextBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#5B6B7F"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>

    <SolidColorBrush x:Key="ButtonBackgroundColor" Color="#1D7CC9" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#186DAF" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#12588D" />
    <SolidColorBrush x:Key="ButtonForegroundColor" Color="White" />

    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#FFA8C6E8" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#FF2B6FB6" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#FFF0F7FF" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBorderBrush" Color="#FF7FB0E2" />
    <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#FFE4F0FC" />
    <SolidColorBrush x:Key="SecondaryButtonPressedBorderBrush" Color="#FF5A97D5" />

    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#FFB91C1C" />
    <SolidColorBrush x:Key="DangerButtonBorderBrush" Color="#FFB91C1C" />
    <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#FFF1F5F9" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#FF991B1B" />
    <SolidColorBrush x:Key="DangerButtonHoverBorderBrush" Color="#FF991B1B" />
    <SolidColorBrush x:Key="DangerButtonPressedBrush" Color="#FF7F1D1D" />
    <SolidColorBrush x:Key="DangerButtonPressedBorderBrush" Color="#FF7F1D1D" />
    <SolidColorBrush x:Key="TertiaryHoverBrush" Color="#FFF0F7FF" />
    <SolidColorBrush x:Key="TertiaryPressedBrush" Color="#FFE4F0FC" />
    <SolidColorBrush x:Key="LinkBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="LinkHoverBrush" Color="#1E40AF" />

    <SolidColorBrush x:Key="TextBoxBorderColor" Color="#FFD4DCE6" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#FF60A5FA" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#0F172A" />

    <SolidColorBrush x:Key="AuthCardBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AuthCardBorderBrush" Color="#FFD9E2EC" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#FFD9E2EC" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FFD9E2EC"/>
</ResourceDictionary>
