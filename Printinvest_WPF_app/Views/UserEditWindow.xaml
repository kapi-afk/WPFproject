<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Printinvest_WPF_app.Converters"
        Title="{DynamicResource UserEditWindowTitle}"
        Height="500"
        Width="620"
        MinHeight="480"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{DynamicResource UserEditWindowTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       FontSize="22"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Visibility="{Binding IsSelectedUserClient, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource LastNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserLastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="{DynamicResource FirstNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserFirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="{DynamicResource MiddleNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserMiddleName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsSelectedUserNonClient, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource FirstNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUser.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource ColumnRole}" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableRoles}"
                              SelectedItem="{Binding SelectedUserRole}"
                              Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource UserRoleConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Visibility="{Binding IsSelectedUserClient, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource EmailLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource ColumnLogin}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding SelectedUser.Login, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <StackPanel Visibility="{Binding IsSelectedUserMaster, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource MasterSpecializationLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <CheckBox Content="{DynamicResource SpecializationLaptops}"
                                  IsChecked="{Binding SelectedUserSpecializesLaptops}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="{DynamicResource SpecializationComputers}"
                                  IsChecked="{Binding SelectedUserSpecializesComputers}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="{DynamicResource SpecializationOfficeEquipment}"
                                  IsChecked="{Binding SelectedUserSpecializesOfficeEquipment}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="{DynamicResource CancelButton}"
                        Style="{StaticResource MediumSecondaryButtonStyle}"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Content="{DynamicResource SaveButton}"
                        Style="{StaticResource MediumPrimaryButtonStyle}"
                        Width="150"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
