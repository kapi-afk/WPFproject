<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.UserCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Printinvest_WPF_app.Converters"
        Title="Создание учетной записи"
        Height="470"
        Width="520"
        MinHeight="470"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Создание учетной записи"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,18"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Имя" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewUserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewUserLogin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Пароль" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewUserPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="Роль" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AvailableRoles}"
                          SelectedItem="{Binding NewUserRole}"
                          Margin="0,0,0,12"/>
                <StackPanel Visibility="{Binding IsNewUserMaster, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Специализация мастера" Margin="0,0,0,6"/>
                    <CheckBox Content="Ноутбуки"
                              IsChecked="{Binding NewUserSpecializesLaptops}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="ПК и моноблоки"
                              IsChecked="{Binding NewUserSpecializesComputers}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="Мониторы и принтеры"
                              IsChecked="{Binding NewUserSpecializesOfficeEquipment}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Отмена"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Style="{StaticResource SmallSecondaryButtonStyle}"/>
            <Button Content="Создать"
                    Width="120"
                    Click="Create_Click"
                    Style="{StaticResource SmallPrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
