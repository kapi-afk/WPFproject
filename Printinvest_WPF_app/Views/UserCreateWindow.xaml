<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.UserCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Printinvest_WPF_app.Converters"
        Title="{DynamicResource UserCreateWindowTitle}"
        Height="470"
        Width="520"
        MinHeight="470"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource UserCreateWindowTitle}"
                   Style="{StaticResource PageTitleStyle}"
                   FontSize="22"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource FirstNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox Text="{Binding NewUserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource ColumnLogin}" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox Text="{Binding NewUserLogin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource PasswordPlaceholder}" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox Text="{Binding NewUserPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource ColumnRole}" Style="{StaticResource FieldLabelStyle}"/>
                <ComboBox ItemsSource="{Binding AvailableRoles}"
                          SelectedItem="{Binding NewUserRole}"
                          Margin="0,0,0,12">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource UserRoleConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <StackPanel Visibility="{Binding IsNewUserMaster, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource MasterSpecializationLabel}" Style="{StaticResource FieldLabelStyle}"/>
                    <CheckBox Content="{DynamicResource SpecializationLaptops}"
                              IsChecked="{Binding NewUserSpecializesLaptops}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="{DynamicResource SpecializationComputers}"
                              IsChecked="{Binding NewUserSpecializesComputers}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="{DynamicResource SpecializationOfficeEquipment}"
                              IsChecked="{Binding NewUserSpecializesOfficeEquipment}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="{DynamicResource CancelButton}"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Style="{StaticResource SmallSecondaryButtonStyle}"/>
            <Button Content="{DynamicResource CreateActionButton}"
                    Width="120"
                    Click="Create_Click"
                    Style="{StaticResource SmallPrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
