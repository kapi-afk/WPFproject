<Window x:Class="Printinvest_WPF_app.Views.MaterialRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создать заявку на материал"
        Height="430"
        Width="460"
        MinHeight="430"
        MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Создать заявку"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding TargetOrderText}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,14"/>

        <TextBlock Grid.Row="2" Text="Что нужно заказать" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3"
                 Text="{Binding RequestMaterialName, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="120"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 MinHeight="72"
                 Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Text="Категория" Margin="0,0,0,4"/>
        <TextBox Grid.Row="5"
                 Text="{Binding RequestMaterialCategory, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="80"
                 Margin="0,0,0,10"/>

        <Grid Grid.Row="6" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Количество" Margin="0,0,0,4"/>
                <TextBox Text="{Binding MaterialUsageQuantity, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Выбрано со склада" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SelectedWarehouseItem.Name, TargetNullValue=Не выбрано}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Создать заявку"
                    Width="150"
                    Click="Create_Click"/>
        </StackPanel>
    </Grid>
</Window>
