<Window x:Class="Printinvest_WPF_app.Views.WarehouseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Склад"
        Height="720"
        Width="1120"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Склад материалов"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,12,0"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding CategoryFilters}"
                      SelectedItem="{Binding SelectedCategoryFilter}"
                      Margin="0,0,12,0"/>
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSortOption}"
                      Margin="0,0,12,0"/>
            <Button Grid.Column="3"
                    Content="Обновить"
                    Command="{Binding RefreshCommand}"
                    Width="110"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding WarehouseItems}"
                      SelectedItem="{Binding SelectedWarehouseItem}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,0,12,0"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalScrollBarVisibility="Disabled">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Материал" Binding="{Binding Name}" Width="1.8*"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="1.2*"/>
                    <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="0.9*"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox Grid.Column="1" Header="Работа с материалом">
                <StackPanel Margin="12">
                    <TextBlock Text="{Binding TargetOrderText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Выбранный материал" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedWarehouseItem.Name, TargetNullValue=Не выбран}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Категория" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedWarehouseItem.Category, TargetNullValue=Не указана}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Остаток" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedWarehouseItem.Quantity, TargetNullValue=0}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Цена за единицу" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedWarehouseItem.UnitPrice, StringFormat={}{0:N2}, TargetNullValue=0}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Количество для списания" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MaterialUsageQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>
                    <Button Content="Создать заявку"
                            Click="CreateRequest_Click"
                            Margin="0,0,0,8"/>
                    <Button Content="Списать на заявку"
                            Command="{Binding ConsumeWarehouseItemCommand}"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
