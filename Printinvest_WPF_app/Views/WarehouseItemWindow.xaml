<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.WarehouseItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WarehouseItemWindowTitle}"
        Height="430"
        Width="520"
        MinHeight="430"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="WindowTitleText"
                   Text="{DynamicResource WarehouseItemNewTitle}"
                   Style="{StaticResource PageTitleStyle}"
                   FontSize="22"/>

        <TextBlock Grid.Row="1" Text="{DynamicResource WarehouseNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox Grid.Row="2" x:Name="NameTextBox" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="{DynamicResource ColumnCategory}" Style="{StaticResource FieldLabelStyle}"/>
        <TextBox Grid.Row="4" x:Name="CategoryTextBox" Margin="0,0,0,12"/>

        <Grid Grid.Row="5" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource QuantityLabel}" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="QuantityTextBox"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource UnitPriceLabel}" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="UnitPriceTextBox"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource CancelButton}"
                    Style="{StaticResource MediumSecondaryButtonStyle}"
                    Width="136"
                    Height="42"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="{DynamicResource SaveButton}"
                    Width="136"
                    Height="42"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
