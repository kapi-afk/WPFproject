<Window x:Class="Printinvest_WPF_app.Views.WarehouseItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция склада"
        Height="360"
        Width="430"
        MinHeight="360"
        MinWidth="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="WindowTitleText"
                   Text="Новая позиция"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,14"/>

        <TextBlock Grid.Row="1" Text="Название" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="NameTextBox" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Категория" Margin="0,0,0,4"/>
        <TextBox Grid.Row="4" x:Name="CategoryTextBox" Margin="0,0,0,10"/>

        <Grid Grid.Row="5" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Количество" Margin="0,0,0,4"/>
                <TextBox x:Name="QuantityTextBox"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Цена за единицу" Margin="0,0,0,4"/>
                <TextBox x:Name="UnitPriceTextBox"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Сохранить"
                    Width="140"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
