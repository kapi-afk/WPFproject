<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.AdminOrderCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource CreateOrderButton}"
        Width="700"
        Height="700"
        MinWidth="700"
        MinHeight="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="OrderSingleLineTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="OrderComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="IsEditable" Value="False"/>
        </Style>
        <Style x:Key="RequiredOrderTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource OrderSingleLineTextBoxStyle}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RequiredOrderMultiLineTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RequiredOrderComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource OrderComboBoxStyle}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource DialogCardStyle}"
            Margin="14">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="650">
            <StackPanel>
                <TextBlock Text="{DynamicResource NewOrderDialogTitle}"
                           Style="{StaticResource PageTitleStyle}"
                           FontSize="26"/>

                <Border Style="{StaticResource InnerCardStyle}"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource ClientNameRequiredLabel}"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding NewOrderClientName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource RequiredOrderTextBoxStyle}"
                                     Tag="{Binding IsNewOrderClientNameInvalid}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource ClientEmailRequiredLabel}"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding NewOrderClientEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource RequiredOrderTextBoxStyle}"
                                     Tag="{Binding IsNewOrderClientEmailInvalid}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0">
                        <TextBlock Text="{DynamicResource DeviceTypeRequiredLabel}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="DeviceTypeComboBox"
                                  ItemsSource="{Binding DeviceTypes}"
                                  SelectedItem="{Binding NewOrderDeviceType}"
                                  Margin="0,0,0,12"
                                  Style="{StaticResource OrderComboBoxStyle}"
                                  SelectionChanged="DeviceTypeComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CatalogOptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox x:Name="CustomDeviceTypeTextBox"
                                 Margin="0,0,0,12"
                                 Visibility="Collapsed"
                                 Style="{StaticResource RequiredOrderTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2">
                        <TextBlock Text="{DynamicResource ModelRequiredLabel}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ModelComboBox"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource RequiredOrderComboBoxStyle}"
                                  SelectionChanged="ModelComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CatalogOptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox x:Name="CustomModelTextBox"
                                 Margin="0,0,0,12"
                                 Visibility="Collapsed"
                                 Style="{StaticResource RequiredOrderTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0">
                        <TextBlock Text="{DynamicResource BrandRequiredLabel}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="BrandComboBox"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource RequiredOrderComboBoxStyle}"
                                  SelectionChanged="BrandComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CatalogOptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox x:Name="CustomBrandTextBox"
                                 Margin="0,0,0,12"
                                 Visibility="Collapsed"
                                 Style="{StaticResource RequiredOrderTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="2">
                        <TextBlock Text="{DynamicResource ProblemRequiredLabel}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ProblemComboBox"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource RequiredOrderComboBoxStyle}"
                                  SelectionChanged="ProblemComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CatalogOptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox x:Name="CustomProblemTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="92"
                                 Visibility="Collapsed"
                                 Style="{StaticResource RequiredOrderMultiLineTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="0">
                        <TextBlock Text="{DynamicResource PhoneRequiredLabel}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewOrderContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,4"
                                 ToolTip="{DynamicResource PhoneHint}"
                                 Style="{StaticResource RequiredOrderTextBoxStyle}"
                                 Tag="{Binding IsNewOrderContactPhoneInvalid}"/>
                        <TextBlock Text="{DynamicResource PhoneHint}"
                                   Style="{StaticResource InfoTextStyle}"
                                   Margin="0,0,0,12"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="2">
                        <TextBlock Text="{DynamicResource PaymentMethodLabel}"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,0,0,4"/>
                        <CheckBox Content="{DynamicResource OnlinePaymentCheckbox}"
                                  IsChecked="{Binding NewOrderIsOnlinePayment}"
                                  FontSize="15"
                                  Margin="0,6,0,6"/>
                        <TextBlock Text="{DynamicResource PaymentHint}"
                                   Style="{StaticResource InfoTextStyle}"
                                   Margin="0,0,0,12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <Border Style="{StaticResource InnerCardStyle}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ProblemPhotoLabel}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Text="{DynamicResource ProblemPhotoHint}"
                                   Style="{StaticResource InfoTextStyle}"
                                   Margin="0,4,0,12"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <Button Content="{DynamicResource AddPhotoButton}"
                                    Style="{StaticResource MediumPrimaryButtonStyle}"
                                    Width="156"
                                    Margin="0,0,10,0"
                                    Click="SelectProblemPhoto_Click"/>
                            <Button x:Name="RemovePhotoButton"
                                    Content="{DynamicResource RemovePhotoButton}"
                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                    Width="118"
                                    Visibility="Collapsed"
                                    Click="RemoveProblemPhoto_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="ProblemPhotoStatusTextBlock"
                                   Text="{DynamicResource ProblemPhotoNotAdded}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,0,0,10"/>

                        <Border x:Name="ProblemPhotoPreviewBorder"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8"
                                Visibility="Collapsed">
                            <Image x:Name="ProblemPhotoPreview"
                                   Height="150"
                                   Stretch="Uniform"/>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock Text="{DynamicResource CommentLabel}"
                           Style="{StaticResource FieldLabelStyle}"/>
                <TextBox Text="{Binding NewOrderClientComment, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="84"
                         Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="{DynamicResource SendOrderButton}"
                            Style="{StaticResource MediumPrimaryButtonStyle}"
                            MinWidth="190"
                            Margin="0,0,10,0"
                            Click="Create_Click"/>
                    <Button Content="{DynamicResource CancelButton}"
                            Style="{StaticResource MediumSecondaryButtonStyle}"
                            Width="96"
                            Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
