<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.AdminOrderCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформить заявку"
        Height="680"
        Width="620"
        MinHeight="560"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Оформить заявку"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Имя клиента" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewOrderClientName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBlock Text="Email клиента" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewOrderClientEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBlock Text="Телефон" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewOrderContactPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBlock Text="Тип устройства" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DeviceTypes}"
                              SelectedItem="{Binding NewOrderDeviceType}"
                              Margin="0,0,0,12"/>
                    <TextBlock Text="Бренд" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewOrderDeviceBrand, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Модель" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewOrderDeviceModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <TextBlock Text="Неисправность" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewOrderProblemDescription, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="92"
                             Margin="0,0,0,12"/>
                    <TextBlock Text="Передача техники" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DeliveryMethods}"
                              SelectedItem="{Binding NewOrderDeliveryMethod}"
                              Margin="0,0,0,12"/>
                    <TextBlock Text="Адрес для курьера"
                               Margin="0,0,0,4"
                               Visibility="{Binding IsCourierDeliverySelected, Converter={StaticResource BoolToVis}}"/>
                    <TextBox Text="{Binding NewOrderDeliveryAddress, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="70"
                             Margin="0,0,0,12"
                             Visibility="{Binding IsCourierDeliverySelected, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Комментарий" Margin="0,4,0,4"/>
            <TextBox Text="{Binding NewOrderClientComment, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="78"
                     Margin="0,0,0,18"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Content="Создать заявку"
                        Width="160"
                        Click="Create_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
