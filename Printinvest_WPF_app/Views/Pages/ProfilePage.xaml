<Page x:Class="Printinvest_WPF_app.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:Printinvest_WPF_app.ViewModels"
      xmlns:conv="clr-namespace:Printinvest_WPF_app.Converters"
      mc:Ignorable="d"
      Title="ProfilePage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Page.DataContext>
        <vm:ServiceClientProfileViewModel />
    </Page.DataContext>

    <Page.Resources>
        <conv:OrderStatusConverter x:Key="OrderStatusConverter" />
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="4,12,6,24"
              MaxWidth="1500"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Профиль клиента"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,18"/>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="#F8FAFC"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24"
                    VerticalAlignment="Top">
                <StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,22">
                        <Border Width="118"
                                Height="118"
                                CornerRadius="59"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1.5"
                                Background="White">
                                
                            </Border>

                        <Button Content="{Binding PhotoActionText}"
                                Command="{Binding ChangePhotoCommand}"
                                Width="132"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Основные данные"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,14"/>

                    <Border Background="White"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Имя"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentUser.Name}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding CurrentUser.Name, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16"
                                     Margin="0,0,0,12"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Логин"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentUser.Login}"
                                       FontSize="16"
                                       Margin="0,0,0,12"
                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding CurrentUser.Login, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16"
                                     Margin="0,0,0,12"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Электронная почта"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CurrentUser.Email}"
                                       FontSize="16"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding CurrentUser.Email, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16"
                                     Margin="0,0,0,4"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="На этот адрес приходят уведомления о статусе ремонта."
                                       FontSize="12"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Редактировать"
                                        Command="{Binding ToggleEditCommand}"
                                        Width="128"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                <Button Content="Сохранить"
                                        Command="{Binding SaveCommand}"
                                        Width="110"
                                        Margin="0"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="Выйти"
                            Command="{Binding LogoutCommand}"
                            Width="96"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Grid.Column="2">
                <Border Background="#F8FAFC"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="22"
                        Margin="0,0,0,18">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Мои заявки"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Здесь отображаются созданные вами заявки, назначенный мастер и текущий статус ремонта."
                                   TextWrapping="Wrap"
                                   Foreground="#5B6B7F"
                                   Margin="0,0,0,18"/>

                        <Border Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="18"
                                Visibility="{Binding HasOrders, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <TextBlock Text="У вас пока нет заявок. Создайте первую через кнопку выше."
                                       TextWrapping="Wrap"
                                       Foreground="#5B6B7F"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Orders}"
                                      Visibility="{Binding HasOrders, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="18"
                                            Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Заявка #"
                                                               Foreground="#64748B"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding Id}"
                                                               FontWeight="Bold"
                                                               Margin="4,0,0,0"/>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Background="#E8F1FB"
                                                        CornerRadius="999"
                                                        Padding="10,4">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource OrderStatusConverter}}"
                                                               Foreground="#0F4C81"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"/>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Устройство" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding DeviceType}" FontWeight="SemiBold"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Бренд и модель" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock>
                                                        <Run Text="{Binding DeviceBrand}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding DeviceModel}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="{Binding DetailsButtonText}"
                                                        Command="{Binding DataContext.ToggleOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Width="104"
                                                        Height="34"
                                                        Margin="16,0,0,0"
                                                        VerticalAlignment="Center"/>
                                            </Grid>

                                            <StackPanel Grid.Row="2"
                                                        Visibility="{Binding IsDetailsExpanded, Converter={StaticResource BoolToVis}}">
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Мастер" FontSize="12" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding AssignedMaster.Name, TargetNullValue=Не назначен}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Передача техники" FontSize="12" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding DeliveryMethod, TargetNullValue=Самовывоз}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Телефон" FontSize="12" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding ContactPhone}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Margin="0,0,0,10">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DeliveryMethod}" Value="Курьер">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="Адрес для курьера" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding DeliveryAddress}" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <TextBlock Text="Описание неисправности" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ProblemDescription}" TextWrapping="Wrap"/>

                                                <StackPanel Margin="0,10,0,0">
                                                    <TextBlock Text="Комментарий клиента" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding ClientComment, TargetNullValue=Нет комментария}" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <Border Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="8"
                                                        Margin="0,10,0,0"
                                                        Visibility="{Binding HasProblemPhoto, Converter={StaticResource BoolToVis}}">
                                                    <Image Source="{Binding ProblemPhoto, Converter={StaticResource ByteArrayToImageConverter}}"
                                                           Height="120"
                                                           Stretch="Uniform"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="Создать заявку"
                                Command="{Binding ToggleCreateOrderFormCommand}"
                                Width="148"
                                Height="36"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <Border Background="#F8FAFC"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Text="Отзывы о сервисе"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Здесь можно оставить свой отзыв и посмотреть, что пишут другие клиенты."
                                   TextWrapping="Wrap"
                                   Foreground="#5B6B7F"
                                   Margin="0,0,0,18"/>

                        <Border Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="18"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Новый отзыв"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>
                                <TextBox Text="{Binding NewReviewText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="90"
                                         Margin="0,0,0,12"/>
                                <Button Content="Оставить отзыв"
                                        Command="{Binding AddReviewCommand}"
                                        Width="146"
                                        HorizontalAlignment="Left"
                                        Margin="0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="18"
                                Visibility="{Binding HasReviews, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <TextBlock Text="Пока отзывов нет. Вы можете оставить первый."
                                       TextWrapping="Wrap"
                                       Foreground="#5B6B7F"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Reviews}"
                                      Visibility="{Binding HasReviews, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="18"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding User.Name}"
                                                           FontWeight="Bold"
                                                           FontSize="16"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                           Foreground="#64748B"
                                                           FontSize="12"/>
                                            </Grid>

                                            <TextBlock Text="{Binding Text}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        </ScrollViewer>

        <Grid Background="#66000000"
              Visibility="{Binding IsCreateOrderFormVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White"
                    BorderBrush="#D7E3F1"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22"
                    Width="760"
                    MaxWidth="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="760">
                <StackPanel>
                    <TextBlock Text="Новая заявка"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,18"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Тип устройства"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding DeviceTypes}"
                                      SelectedItem="{Binding NewOrderDeviceType}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="Бренд"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding BrandOptions}"
                                      SelectedItem="{Binding SelectedBrandOption}"
                                      Margin="0,0,0,8"/>
                            <TextBox Text="{Binding CustomBrand, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     Visibility="{Binding IsCustomBrandVisible, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Телефон"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewOrderContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Передача техники"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding DeliveryMethods}"
                                      SelectedItem="{Binding NewOrderDeliveryMethod}"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="Адрес для курьера"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"
                                       Visibility="{Binding IsCourierDeliverySelected, Converter={StaticResource BoolToVis}}"/>
                            <TextBox Text="{Binding NewOrderDeliveryAddress, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="72"
                                     Visibility="{Binding IsCourierDeliverySelected, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Модель"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding ModelOptions}"
                                      SelectedItem="{Binding SelectedModelOption}"
                                      Margin="0,0,0,8"/>
                            <TextBox Text="{Binding CustomModel, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     Visibility="{Binding IsCustomModelVisible, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Неисправность"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding ProblemOptions}"
                                      SelectedItem="{Binding SelectedProblemOption}"
                                      Margin="0,0,0,8"/>
                            <TextBox Text="{Binding CustomProblemDescription, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="92"
                                     Visibility="{Binding IsCustomProblemVisible, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Фото неисправности"
                                       FontSize="12"
                                       Foreground="#64748B"/>
                            <TextBlock Text="Необязательно, но поможет мастеру быстрее понять проблему."
                                       Foreground="#5B6B7F"
                                       Margin="0,4,0,12"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <Button Content="Добавить фото"
                                        Command="{Binding SelectProblemPhotoCommand}"
                                        Width="126"
                                        Margin="0,0,10,0"/>
                                <Button Content="Удалить фото"
                                        Command="{Binding RemoveProblemPhotoCommand}"
                                        Width="118"
                                        Visibility="{Binding HasSelectedProblemPhoto, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding NewOrderProblemPhotoStatus}"
                                       Foreground="#5B6B7F"
                                       Margin="0,0,0,10"/>

                            <Border Background="White"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8"
                                    Visibility="{Binding HasSelectedProblemPhoto, Converter={StaticResource BoolToVis}}">
                                <Image Source="{Binding NewOrderProblemPhoto, Converter={StaticResource ByteArrayToImageConverter}}"
                                       Height="150"
                                       Stretch="Uniform"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Комментарий"
                               FontSize="12"
                               Foreground="#64748B"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewOrderClientComment, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="84"
                             Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <Button Content="Отправить заявку"
                                Command="{Binding CreateOrderCommand}"
                                Width="150"
                                Margin="0,0,10,0"/>
                        <Button Content="Отмена"
                                Command="{Binding CancelCreateOrderFormCommand}"
                                Width="96"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
