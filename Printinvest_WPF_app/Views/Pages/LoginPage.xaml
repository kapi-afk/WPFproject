<Page x:Class="Printinvest_WPF_app.Views.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:Printinvest_WPF_app.ViewModels"
      mc:Ignorable="d"
      Title="LoginPage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Page.DataContext>
        <vm:LoginViewModel />
    </Page.DataContext>

    <Grid>
        <Border Width="460"
                Padding="32"
                CornerRadius="20"
                Background="#F8FAFC"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                KeyDown="LoginKeyDown"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Вход"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Войдите в учетную запись, чтобы открыть свой кабинет по роли."
                           TextWrapping="Wrap"
                           Foreground="#5B6B7F"
                           TextAlignment="Center"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Логин"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Width="360"
                         Height="44"
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,14"/>

                <TextBlock Text="Пароль"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <PasswordBox Grid.Row="2"
                             x:Name="PasswordBox"
                             PasswordChar="*"
                             Width="360"
                             Height="44"
                             FontSize="16"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,18"/>

                <Button Content="Войти"
                        Command="{Binding LoginCommand}"
                        Width="180"
                        Height="42"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock>
                        <Hyperlink NavigateUri="RegisterPage.xaml" Command="{Binding NavigateCommand}" CommandParameter="Register">
                            <Run Text="Зарегистрироваться"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text=" | " Margin="6,0"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="RecoverPage.xaml" Command="{Binding NavigateCommand}" CommandParameter="Recover">
                            <Run Text="Восстановить пароль"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
