<Page x:Class="Printinvest_WPF_app.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Сервис по ремонту вычислительной техники"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1"
                   Text="В этой версии уже можно зарегистрироваться, создать заявку на ремонт, назначить мастера, менять статусы и смотреть отзывы о сервисе."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextBrush}"
                   Opacity="0.85"
                   Margin="0,0,0,20"/>

        <WrapPanel Grid.Row="2">
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,16,16" Width="240">
                <StackPanel>
                    <TextBlock Text="Клиент" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="Регистрируется, создает заявку на ремонт, отслеживает статус и оставляет отзыв." TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,16,16" Width="240">
                <StackPanel>
                    <TextBlock Text="Администратор" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="Управляет пользователями, назначает мастеров, контролирует заявки и смотрит сводную статистику." TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,16,16" Width="240">
                <StackPanel>
                    <TextBlock Text="Мастер" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="Видит только свои заявки и переводит их по этапам ремонта." TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </WrapPanel>
    </Grid>
</Page>
