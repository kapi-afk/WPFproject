<Page x:Class="Printinvest_WPF_app.Views.Pages.AdminPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:Printinvest_WPF_app.ViewModels"
      mc:Ignorable="d"
      Title="AdminPanelPage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="18,12,18,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource AdminPanelTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>
        </Grid>

        <TabControl Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}">
            <TabItem Header="{DynamicResource UsersTab}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,10">
                        <Button Content="{DynamicResource CreateAccountButton}"
                                Command="{Binding ShowCreateUserFormCommand}"
                                Style="{StaticResource MediumPrimaryButtonStyle}"
                                Width="187" Height="39" Click="Button_Click" FontSize="12"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColumnId}" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnLogin}" Binding="{Binding Login}" Width="2*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnName}" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnRole}" Binding="{Binding Role}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="260">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="{DynamicResource EditButton}"
                                                    Width="96"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.BeginEditUserCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="{DynamicResource DeleteButton}"
                                                    Width="96"
                                                    Style="{StaticResource SmallDangerButtonStyle}"
                                                    Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource OrdersTab}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,10">
                        <Button Content="{DynamicResource ManageOrderButton}"
                                Command="{Binding ShowEditOrderFormCommand}"
                                Style="{StaticResource MediumSecondaryButtonStyle}"
                                Width="186"
                                Height="36"
                                FontSize="13"
                                Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource CreateOrderButton}"
                                Command="{Binding ShowCreateAdminOrderFormCommand}"
                                Style="{StaticResource MediumPrimaryButtonStyle}"
                                Width="162"
                                Height="36"
                                FontSize="13"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColumnNumber}" Binding="{Binding DisplayNumber}" Width="95"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnClient}" Binding="{Binding User.Name}" Width="1.5*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnDevice}" Binding="{Binding DeviceType}" Width="1.4*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnBrand}" Binding="{Binding DeviceBrand}" Width="1.2*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnModel}" Binding="{Binding DeviceModel}" Width="1.2*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnPayment}" Binding="{Binding PaymentStatusText}" Width="1.3*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnAmountByn}" Binding="{Binding EstimatedRepairCost, StringFormat={}{0:N2}}" Width="1.1*"/>
                            <DataGridTemplateColumn Header="{DynamicResource ColumnStatus}" Width="1.4*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding Status}"
                                                        ContentTemplate="{StaticResource OrderStatusBadgeTemplate}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource ColumnMaster}" Binding="{Binding AssignedMaster.Name}" Width="1.3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource StatisticsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">
                        <TextBlock Text="{DynamicResource ServiceSummaryTitle}" Style="{StaticResource SectionTitleStyle}" FontSize="20" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource InnerCardStyle}" MinHeight="104" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource TotalOrdersLabel}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalOrdersCount}" FontSize="24"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource InnerCardStyle}" MinHeight="104" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ActiveOrdersLabel}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ActiveOrdersCount}" FontSize="24"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource InnerCardStyle}" MinHeight="104" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CompletedOrdersLabel}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CompletedOrdersCount}" FontSize="24"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="6" Style="{StaticResource InnerCardStyle}" MinHeight="104" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource MastersLabel}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding MastersCount}" FontSize="24"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="8" Style="{StaticResource InnerCardStyle}" MinHeight="104" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ClientsLabel}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ClientsCount}" FontSize="24"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource InnerCardStyle}"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource OrderStatusesChartTitle}"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <Grid Width="240"
                                          Height="240"
                                          HorizontalAlignment="Center">
                                        <Ellipse Width="184"
                                                 Height="184"
                                                 Stroke="{DynamicResource CardBorderBrush}"
                                                 StrokeThickness="34"
                                                 Opacity="0.45"/>
                                        <ItemsControl ItemsSource="{Binding OrderStatusChartSlices}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Width="240" Height="240"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Path Data="{Binding Geometry}"
                                                          Fill="{Binding Fill}"
                                                          Stretch="None"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TotalOrdersCount}"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource OrdersInnerCaption}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource InnerCardStyle}"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource StatusesTitle}"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <ItemsControl ItemsSource="{Binding OrderStatusChartSlices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12"
                                                        Margin="0,0,0,10"
                                                        Background="{DynamicResource PanelBackgroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="12"
                                                                Height="12"
                                                                CornerRadius="6"
                                                                Background="{Binding Fill}"
                                                                VerticalAlignment="Top"
                                                                Margin="0,3,12,0"/>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="14"/>
                                                            <TextBlock Text="{Binding SummaryText}"
                                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                                       FontSize="12"/>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding PercentageText}"
                                                                   FontWeight="Bold"
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="{DynamicResource NoOrdersChartText}"
                                               Style="{StaticResource SectionHintStyle}"
                                               Margin="0,6,0,0"
                                               Visibility="{Binding HasOrderStatusChartData, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource WarehouseTab}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,12,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                          <Button Grid.Column="0"
                                  Content="{DynamicResource CreateWarehouseItemButton}"
                                  Command="{Binding ShowCreateWarehouseFormCommand}"
                                  Style="{StaticResource MediumPrimaryButtonStyle}"
                                  Width="156"
                                  Height="38"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>

                          <TextBox Grid.Column="2"
                                   Text="{Binding WarehouseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                   Width="220"
                                   Height="38"
                                   FontSize="12"
                                   VerticalContentAlignment="Center"
                                   VerticalAlignment="Center"/>
                          <ComboBox Grid.Column="4"
                                    ItemsSource="{Binding WarehouseCategoryFilters}"
                                    SelectedItem="{Binding SelectedWarehouseCategoryFilter}"
                                    Width="170"
                                    Height="38"
                                    FontSize="12"
                                    VerticalAlignment="Center"/>
                          <ComboBox Grid.Column="6"
                                    ItemsSource="{Binding WarehouseSortOptions}"
                                    SelectedItem="{Binding SelectedWarehouseSortOption}"
                                    Width="170"
                                    Height="38"
                                    FontSize="12"
                                    VerticalAlignment="Center"/>

                          <Button Grid.Column="8"
                                  Content="{DynamicResource MasterRequestsButton}"
                                  Command="{Binding ShowWarehouseRequestsCommand}"
                                  Style="{StaticResource MediumSecondaryButtonStyle}"
                                  Width="156"
                                  Height="38"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                      </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding WarehouseItems}"
                              SelectedItem="{Binding SelectedWarehouseItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColumnId}" Binding="{Binding Id}" Width="55"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnMaterial}" Binding="{Binding Name}" Width="2.2*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnCategory}" Binding="{Binding Category}" Width="1.4*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnStock}" Binding="{Binding Quantity}" Width="1*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnPriceByn}" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="1*"/>
                            <DataGridTemplateColumn Header="" Width="240">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="{DynamicResource EditButton}"
                                                    Width="96"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.ToggleEditWarehouseItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="{DynamicResource DeleteButton}"
                                                    Width="96"
                                                    Style="{StaticResource SmallDangerButtonStyle}"
                                                    Command="{Binding DataContext.DeleteWarehouseItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
