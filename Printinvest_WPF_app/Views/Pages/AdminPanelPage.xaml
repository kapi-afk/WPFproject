<Page x:Class="Printinvest_WPF_app.Views.Pages.AdminPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:Printinvest_WPF_app.ViewModels"
      mc:Ignorable="d"
      Title="AdminPanelPage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="18,12,18,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource AdminPanelTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>
        </Grid>

        <TabControl Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}">
            <TabItem Header="{DynamicResource UsersTab}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,10">
                        <Button Content="Создать учетную запись"
                                Command="{Binding ShowCreateUserFormCommand}"
                                Style="{StaticResource MediumPrimaryButtonStyle}"
                                Width="187" Height="39" Click="Button_Click" FontSize="12"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="2*"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="260">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Изменить"
                                                    Width="96"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.BeginEditUserCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Удалить"
                                                    Width="96"
                                                    Style="{StaticResource SmallDangerButtonStyle}"
                                                    Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource OrdersTab}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,10">
                        <Button Content="Управление заявкой"
                                Command="{Binding ShowEditOrderFormCommand}"
                                Style="{StaticResource MediumSecondaryButtonStyle}"
                                Width="186"
                                Height="36"
                                FontSize="11"
                                Margin="0,0,8,0"/>
                        <Button Content="Оформить заявку"
                                Command="{Binding ShowCreateAdminOrderFormCommand}"
                                Style="{StaticResource MediumPrimaryButtonStyle}"
                                Width="162"
                                Height="36"
                                FontSize="11"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding DisplayNumber}" Width="95"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding User.Name}" Width="1.5*"/>
                            <DataGridTextColumn Header="Устройство" Binding="{Binding DeviceType}" Width="1.4*"/>
                            <DataGridTextColumn Header="Бренд" Binding="{Binding DeviceBrand}" Width="1.2*"/>
                            <DataGridTextColumn Header="Модель" Binding="{Binding DeviceModel}" Width="1.2*"/>
                            <DataGridTextColumn Header="Оплата" Binding="{Binding PaymentStatusText}" Width="1.3*"/>
                            <DataGridTextColumn Header="Сумма (BYN)" Binding="{Binding EstimatedRepairCost, StringFormat={}{0:N2}}" Width="1.1*"/>
                            <DataGridTemplateColumn Header="Статус" Width="1.4*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding Status}"
                                                        ContentTemplate="{StaticResource OrderStatusBadgeTemplate}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Мастер" Binding="{Binding AssignedMaster.Name}" Width="1.3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Статистика">
                <StackPanel Margin="20">
                    <TextBlock Text="Сводка по сервису" Style="{StaticResource SectionTitleStyle}" FontSize="20" Margin="0,0,0,16"/>
                    <WrapPanel>
                        <Border Style="{StaticResource InnerCardStyle}" Padding="14" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Всего заявок" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalOrdersCount}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InnerCardStyle}" Padding="14" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Активных заявок" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ActiveOrdersCount}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InnerCardStyle}" Padding="14" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Выполнено" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CompletedOrdersCount}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InnerCardStyle}" Padding="14" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Мастеров" FontWeight="Bold"/>
                                <TextBlock Text="{Binding MastersCount}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InnerCardStyle}" Padding="14" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Клиентов" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ClientsCount}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Склад">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,12,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                          <Button Grid.Column="0"
                                  Content="Добавить позицию"
                                  Command="{Binding ShowCreateWarehouseFormCommand}"
                                  Style="{StaticResource MediumPrimaryButtonStyle}"
                                  Width="156"
                                  Height="38"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>

                          <TextBox Grid.Column="2"
                                   Text="{Binding WarehouseSearchText, UpdateSourceTrigger=PropertyChanged}"
                                   Width="220"
                                   Height="38"
                                   FontSize="12"
                                   VerticalContentAlignment="Center"
                                   VerticalAlignment="Center"/>
                          <ComboBox Grid.Column="4"
                                    ItemsSource="{Binding WarehouseCategoryFilters}"
                                    SelectedItem="{Binding SelectedWarehouseCategoryFilter}"
                                    Width="170"
                                    Height="38"
                                    FontSize="12"
                                    VerticalAlignment="Center"/>
                          <ComboBox Grid.Column="6"
                                    ItemsSource="{Binding WarehouseSortOptions}"
                                    SelectedItem="{Binding SelectedWarehouseSortOption}"
                                    Width="170"
                                    Height="38"
                                    FontSize="12"
                                    VerticalAlignment="Center"/>

                          <Button Grid.Column="8"
                                  Content="Заявки мастеров"
                                  Command="{Binding ShowWarehouseRequestsCommand}"
                                  Style="{StaticResource MediumSecondaryButtonStyle}"
                                  Width="156"
                                  Height="38"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                      </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding WarehouseItems}"
                              SelectedItem="{Binding SelectedWarehouseItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55"/>
                            <DataGridTextColumn Header="Материал" Binding="{Binding Name}" Width="2.2*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="1.4*"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="1*"/>
                            <DataGridTextColumn Header="Цена (BYN)" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="1*"/>
                            <DataGridTemplateColumn Header="" Width="240">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Изменить"
                                                    Width="96"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.ToggleEditWarehouseItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Удалить"
                                                    Width="96"
                                                    Style="{StaticResource SmallDangerButtonStyle}"
                                                    Command="{Binding DataContext.DeleteWarehouseItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
