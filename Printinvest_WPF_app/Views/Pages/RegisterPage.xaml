<Page x:Class="Printinvest_WPF_app.Views.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:Printinvest_WPF_app.ViewModels"
      mc:Ignorable="d"
      Title="RegisterPage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Page.DataContext>
        <vm:RegisterViewModel />
    </Page.DataContext>

    <Grid>
        <Border Width="500"
                Padding="32"
                CornerRadius="20"
                Background="#F8FAFC"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Регистрация"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Публичная регистрация создает учетную запись клиента."
                           TextWrapping="Wrap"
                           Foreground="#5B6B7F"
                           TextAlignment="Center"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Имя"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Width="380"
                         Height="44"
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Логин"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Width="380"
                         Height="44"
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Электронная почта"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Width="380"
                         Height="44"
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
                <TextBlock Text="На эту почту будут приходить уведомления о смене статуса заявки."
                           TextWrapping="Wrap"
                           Foreground="#5B6B7F"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Пароль"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             PasswordChar="*"
                             Width="380"
                             Height="44"
                             FontSize="16"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,12"/>

                <TextBlock Text="Подтверждение пароля"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             PasswordChar="*"
                             Width="380"
                             Height="44"
                             FontSize="16"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,16"/>

                <Button Content="Создать аккаунт"
                        Command="{Binding RegisterCommand}"
                        Width="200"
                        Height="42"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#C62828"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,14"/>

                <TextBlock HorizontalAlignment="Center">
                    <Hyperlink Command="{Binding NavigateToLoginCommand}">
                        <Run Text="У меня уже есть аккаунт"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
