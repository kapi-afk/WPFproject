<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Printinvest_WPF_app.Views.OnlinePaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Онлайн-оплата"
        Width="460"
        Height="560"
        MinWidth="460"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="PaymentTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RequiredPaymentTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource PaymentTextBoxStyle}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Онлайн-оплата"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="{Binding OrderNumber, StringFormat='Заявка {0}'}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DeviceDisplay}"
                               Margin="0,6,0,6"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AmountToPay, StringFormat='К оплате: {0:N2} BYN'}"
                               FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Имя держателя карты *" Margin="0,0,0,4"/>
            <TextBox Text="{Binding CardholderName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12"
                     Style="{StaticResource RequiredPaymentTextBoxStyle}"
                     Tag="{Binding IsCardholderNameInvalid}"/>

            <TextBlock Text="Номер карты *" Margin="0,0,0,4"/>
            <TextBox Text="{Binding CardNumber, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,4"
                     Style="{StaticResource RequiredPaymentTextBoxStyle}"
                     Tag="{Binding IsCardNumberInvalid}"/>
            <TextBlock Text="Введите 16 цифр карты."
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Срок действия *" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ExpiryDate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RequiredPaymentTextBoxStyle}"
                             Tag="{Binding IsExpiryDateInvalid}"/>
                    <TextBlock Text="Формат: MM/YY"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="CVV *" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Cvv, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RequiredPaymentTextBoxStyle}"
                             Tag="{Binding IsCvvInvalid}"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Width="110"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Content="Оплатить"
                        Width="140"
                        Style="{StaticResource MediumPrimaryButtonStyle}"
                        Click="Pay_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
