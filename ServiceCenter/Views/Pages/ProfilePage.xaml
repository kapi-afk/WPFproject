<Page x:Class="ServiceCenter.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:ServiceCenter.ViewModels"
      xmlns:conv="clr-namespace:ServiceCenter.Converters"
      mc:Ignorable="d"
      Title="ProfilePage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Page.Resources>
        <conv:OrderStatusConverter x:Key="OrderStatusConverter" />
        <Style x:Key="OrderSingleLineTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="OrderComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="RequiredOrderTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource OrderSingleLineTextBoxStyle}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RequiredOrderMultiLineTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RequiredOrderComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource OrderComboBoxStyle}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#D13438"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ValidationMessageStyle"
               TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                  MaxWidth="1180"
                  Margin="16,16,18,28"
                  HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.38*"
                                          MinWidth="340"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="0.62*"
                                          MinWidth="520"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="3"
                               Text="{DynamicResource ClientProfilePageTitle}"
                               Style="{StaticResource PageTitleStyle}"/>

                <Border
                            Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Padding="28"
                            MaxWidth="395"
                            VerticalAlignment="Top"
                            Margin="0,55,0,0"
                            Grid.RowSpan="2">
                    <StackPanel Margin="0,19,0,0">
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,22">
                            <Border Width="118"
                                        Height="118"
                                        CornerRadius="59"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1.5"
                                        Background="{DynamicResource InputBackgroundBrush}">
                            </Border>

                            <Button Content="{Binding PhotoActionText}"
                                        Command="{Binding ChangePhotoCommand}"
                                        Width="132"
                                        Style="{StaticResource SmallSecondaryButtonStyle}"
                                        Margin="0,14,0,0"
                                        HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource BasicDataTitle}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       FontSize="18"
                                       Margin="0,0,0,14"/>

                        <Border Style="{StaticResource InnerCardStyle}"
                                    Padding="20"
                                    MaxWidth="366"
                                    HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="{DynamicResource NamePlaceholder}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding CurrentUser.Name}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"
                                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="16"
                                             Margin="0,0,0,12"
                                             Tag="{Binding HasEditNameValidationError}"
                                             Style="{StaticResource RequiredOrderTextBoxStyle}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding EditNameValidationMessage}"
                                               Style="{StaticResource ValidationMessageStyle}"
                                               Visibility="{Binding HasEditNameValidationError, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock Text="{DynamicResource ColumnLogin}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding CurrentUser.Login}"
                                               FontSize="16"
                                               Margin="0,0,0,12"
                                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                    <TextBox Text="{Binding EditLogin, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="16"
                                             Margin="0,0,0,12"
                                             Tag="{Binding HasEditLoginValidationError}"
                                             Style="{StaticResource RequiredOrderTextBoxStyle}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding EditLoginValidationMessage}"
                                               Style="{StaticResource ValidationMessageStyle}"
                                               Visibility="{Binding HasEditLoginValidationError, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock Text="{DynamicResource EmailLabel}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding CurrentUser.Email}"
                                               FontSize="16"
                                               Margin="0,0,0,12"
                                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                    <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="16"
                                             Margin="0,0,0,12"
                                             Tag="{Binding HasEditEmailValidationError}"
                                             Style="{StaticResource RequiredOrderTextBoxStyle}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding EditEmailValidationMessage}"
                                               Style="{StaticResource ValidationMessageStyle}"
                                               Visibility="{Binding HasEditEmailValidationError, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <Grid Grid.Row="1"
                                      Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                                Content="{DynamicResource EditButton}"
                                                Command="{Binding ToggleEditCommand}"
                                                Width="117"
                                                Height="32"
                                                FontSize="12"
                                                Style="{StaticResource SmallSecondaryButtonStyle}"
                                                Visibility="{Binding IsEditing, ConverterParameter=Inverse, Converter={StaticResource BoolToVis}}"/>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                        <Button Content="{DynamicResource CancelButton}"
                                                Command="{Binding CancelEditCommand}"
                                                Width="116"
                                                Height="34"
                                                FontSize="12"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource SmallSecondaryButtonStyle}"/>
                                        <Button Content="{DynamicResource SaveButton}"
                                                Command="{Binding SaveCommand}"
                                                Width="116"
                                                Height="34"
                                                FontSize="12"
                                                Style="{StaticResource SmallPrimaryButtonStyle}"
                                                Margin="0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <Button Content="{DynamicResource LogoutButton}"
                                    Command="{Binding LogoutCommand}"
                                    Width="96"
                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                    Padding="10,0"
                                    Click="Button_Click_1"
                                    Height="31"
                                    HorizontalAlignment="Left"
                                    Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch">
                    <Border Style="{StaticResource CardStyle}"
                                Padding="28"
                                Margin="0,0,0,28">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{DynamicResource MyOrdersTitle}"
                                           Style="{StaticResource SectionTitleStyle}"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Content="{DynamicResource CreateClientOrderButton}"
                                        Command="{Binding ToggleCreateOrderFormCommand}"
                                        Width="148"
                                        Style="{StaticResource MediumPrimaryButtonStyle}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"/>
                            </Grid>

                            <Border Style="{StaticResource InnerCardStyle}"
                                        Visibility="{Binding HasOrders, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <TextBlock Text="{DynamicResource NoOrdersText}"
                                               Style="{StaticResource SectionHintStyle}"
                                               Margin="0"/>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Orders}"
                                              Visibility="{Binding HasOrders, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InnerCardStyle}"
                                                    Padding="18"
                                                    Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{DynamicResource OrderCardTitle}"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       FontSize="12"/>
                                                        <TextBlock Text="{Binding DisplayNumber}"
                                                                       FontWeight="Bold"
                                                                       Margin="4,0,0,0"/>
                                                    </StackPanel>

                                                    <ContentControl Grid.Column="1"
                                                                        Content="{Binding Status}"
                                                                        ContentTemplate="{StaticResource OrderStatusBadgeTemplate}"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center"/>
                                                </Grid>

                                                <Grid Grid.Row="1"
                                                      Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="22"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{DynamicResource DeviceLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        <TextBlock Text="{Binding DeviceType}"
                                                                       FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{DynamicResource BrandModelLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        <TextBlock TextWrapping="Wrap">
                                                                <Run Text="{Binding DeviceBrand}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding DeviceModel}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="2"
                                                      Margin="0,8,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <WrapPanel Grid.Column="0"
                                                               Orientation="Horizontal"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Center">
                                                        <WrapPanel.Style>
                                                            <Style TargetType="WrapPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="False"/>
                                                                            <Condition Binding="{Binding CanShowOnlinePaymentButton}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="False"/>
                                                                            <Condition Binding="{Binding CanBeCancelledByClient}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </WrapPanel.Style>
                                                        <Button Content="{DynamicResource PayButton}"
                                                                Command="{Binding DataContext.PayOrderOnlineCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Width="108"
                                                                Style="{StaticResource SmallPrimaryButtonStyle}"
                                                                Margin="0,0,10,0"
                                                                Visibility="{Binding CanShowOnlinePaymentButton, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="{DynamicResource CancelOrderButton}"
                                                                Command="{Binding DataContext.CancelOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Width="108"
                                                                Style="{StaticResource SmallDangerButtonStyle}"
                                                                Margin="0,0,10,0"
                                                                Visibility="{Binding CanBeCancelledByClient, Converter={StaticResource BoolToVis}}"/>
                                                    </WrapPanel>

                                                    <Button Grid.Column="1"
                                                            Content="{Binding DetailsButtonText}"
                                                            Command="{Binding DataContext.ToggleOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Margin="16,0,0,0"/>
                                                </Grid>

                                                <StackPanel Grid.Row="3"
                                                            Visibility="{Binding IsDetailsExpanded, Converter={StaticResource BoolToVis}}">
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="24"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0"
                                                                    Grid.Column="0"
                                                                    Margin="0,0,0,10">
                                                            <TextBlock Text="{DynamicResource MasterLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding AssignedMaster.Name, TargetNullValue={StaticResource NotAssignedText}}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0"
                                                                    Grid.Column="2"
                                                                    Margin="0,0,0,10">
                                                            <TextBlock Text="{DynamicResource PhoneLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding ContactPhone}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1"
                                                                    Grid.Column="0"
                                                                    Margin="0,0,0,10">
                                                            <TextBlock Text="{DynamicResource DeliveryMethodLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding DeliveryMethodDisplay, TargetNullValue={StaticResource PickupText}}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1"
                                                                    Grid.Column="2"
                                                                    Margin="0,0,0,10">
                                                            <TextBlock Text="{DynamicResource PaymentMethodLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding PaymentMethodDisplay}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2"
                                                                    Grid.Column="0"
                                                                    Margin="0,0,0,10">
                                                            <TextBlock Text="{DynamicResource PaymentStatusLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding PaymentStatusText}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2"
                                                                    Grid.Column="2">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOnlinePaymentCompleted}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{DynamicResource OnlinePaymentDateLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding PaymentPaidAtText}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="3"
                                                                    Grid.ColumnSpan="3"
                                                                    Margin="0,0,0,10">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DeliveryMethod}" Value="Курьер">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{DynamicResource CourierAddressLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding DeliveryAddress}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="4"
                                                                    Grid.Column="0">
                                                            <TextBlock Text="{DynamicResource ProblemDescriptionLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding ProblemDescription}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="4"
                                                                    Grid.Column="2">
                                                            <TextBlock Text="{DynamicResource ClientCommentLabel}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding ClientComment, TargetNullValue={StaticResource NoCommentText}}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="8"
                                                                Margin="0,10,0,0"
                                                                Visibility="{Binding HasProblemPhoto, Converter={StaticResource BoolToVis}}">
                                                        <Image Source="{Binding ProblemPhoto, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                   Height="120"
                                                                   Stretch="Uniform"/>
                                                    </Border>

                                                    <WrapPanel Orientation="Horizontal"
                                                               Margin="0,14,0,0"
                                                               HorizontalAlignment="Left">
                                                        <WrapPanel.Style>
                                                            <Style TargetType="WrapPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="True"/>
                                                                            <Condition Binding="{Binding CanShowOnlinePaymentButton}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="True"/>
                                                                            <Condition Binding="{Binding CanBeCancelledByClient}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </WrapPanel.Style>
                                                        <Button Content="{DynamicResource PayButton}"
                                                                Command="{Binding DataContext.PayOrderOnlineCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Width="108"
                                                                Style="{StaticResource SmallPrimaryButtonStyle}"
                                                                Margin="0,0,10,0"
                                                                Visibility="{Binding CanShowOnlinePaymentButton, Converter={StaticResource BoolToVis}}"/>
                                                        <Button Content="{DynamicResource CancelOrderButton}"
                                                                Command="{Binding DataContext.CancelOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Width="108"
                                                                Style="{StaticResource SmallDangerButtonStyle}"
                                                                Margin="0,0,10,0"
                                                                Visibility="{Binding CanBeCancelledByClient, Converter={StaticResource BoolToVis}}"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ServiceReviewsTitle}"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InnerCardStyle}"
                                        Padding="20"
                                        Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource NewReviewTitle}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,10"/>
                                    <TextBox Text="{Binding NewReviewText, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="90"
                                                 Margin="0,0,0,12"/>
                                    <Button Content="{DynamicResource LeaveReviewButton}"
                                                Command="{Binding AddReviewCommand}"
                                                Style="{StaticResource MediumPrimaryButtonStyle}"
                                                Width="165"
                                                HorizontalAlignment="Left"
                                                Margin="0,15,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCardStyle}"
                                        Padding="20"
                                        Visibility="{Binding HasReviews, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <TextBlock Text="{DynamicResource NoReviewsText}"
                                               Style="{StaticResource SectionHintStyle}"
                                               Margin="0"/>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Reviews}"
                                              Visibility="{Binding HasReviews, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InnerCardStyle}"
                                                    Padding="20"
                                                    Margin="0,0,0,16">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding User.Name}"
                                                                   FontWeight="Bold"
                                                                   FontSize="16"/>
                                                    <TextBlock Grid.Column="1"
                                                                   Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   FontSize="12"/>
                                                </Grid>

                                                <TextBlock Text="{Binding Text}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid Background="#66000000"
              Visibility="{Binding IsCreateOrderFormVisible, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource DialogCardStyle}"
                    Width="680"
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="680">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource NewOrderDialogTitle}"
                               Style="{StaticResource PageTitleStyle}"
                               FontSize="26"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0">
                                <TextBlock Text="{DynamicResource DeviceTypeRequiredLabel}"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding DeviceTypes}"
                                          SelectedItem="{Binding NewOrderDeviceType}"
                                          Margin="0,0,0,12"
                                          Style="{StaticResource OrderComboBoxStyle}"/>
                                <TextBox Text="{Binding CustomDeviceType, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"
                                         Visibility="{Binding IsCustomDeviceTypeVisible, Converter={StaticResource BoolToVis}}"
                                         Style="{StaticResource RequiredOrderTextBoxStyle}"
                                         Tag="{Binding IsNewOrderDeviceTypeInvalid}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="2">
                                <TextBlock Text="{DynamicResource ModelRequiredLabel}"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding ModelOptions}"
                                          SelectedItem="{Binding SelectedModelOption}"
                                          Margin="0,0,0,8"
                                          Style="{StaticResource RequiredOrderComboBoxStyle}"
                                          Tag="{Binding IsNewOrderDeviceModelInvalid}"/>
                                <TextBox Text="{Binding CustomModel, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"
                                         Visibility="{Binding IsCustomModelVisible, Converter={StaticResource BoolToVis}}"
                                         Style="{StaticResource RequiredOrderTextBoxStyle}"
                                         Tag="{Binding IsNewOrderDeviceModelInvalid}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0">
                                <TextBlock Text="{DynamicResource BrandRequiredLabel}"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding BrandOptions}"
                                          SelectedItem="{Binding SelectedBrandOption}"
                                          Margin="0,0,0,8"
                                          Style="{StaticResource RequiredOrderComboBoxStyle}"
                                          Tag="{Binding IsNewOrderDeviceBrandInvalid}"/>
                                <TextBox Text="{Binding CustomBrand, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"
                                         Visibility="{Binding IsCustomBrandVisible, Converter={StaticResource BoolToVis}}"
                                         Style="{StaticResource RequiredOrderTextBoxStyle}"
                                         Tag="{Binding IsNewOrderDeviceBrandInvalid}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="2">
                                <TextBlock Text="{DynamicResource ProblemRequiredLabel}"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding ProblemOptions}"
                                          SelectedItem="{Binding SelectedProblemOption}"
                                          Margin="0,0,0,8"
                                          Style="{StaticResource RequiredOrderComboBoxStyle}"
                                          Tag="{Binding IsNewOrderProblemDescriptionInvalid}"/>
                                <TextBox Text="{Binding CustomProblemDescription, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="92"
                                         Visibility="{Binding IsCustomProblemVisible, Converter={StaticResource BoolToVis}}"
                                         Style="{StaticResource RequiredOrderMultiLineTextBoxStyle}"
                                         Tag="{Binding IsNewOrderProblemDescriptionInvalid}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="0">
                                <TextBlock Text="{DynamicResource PhoneRequiredLabel}"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding NewOrderContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,4"
                                         ToolTip="{DynamicResource PhoneHint}"
                                         Style="{StaticResource RequiredOrderTextBoxStyle}"
                                         Tag="{Binding IsNewOrderContactPhoneInvalid}"/>
                                <TextBlock Text="{DynamicResource PhoneHint}"
                                           Style="{StaticResource InfoTextStyle}"
                                           Margin="0,0,0,12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="2">
                                <TextBlock Text="{DynamicResource PaymentMethodLabel}"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Margin="0,0,0,4"/>
                                <CheckBox Content="{DynamicResource OnlinePaymentCheckbox}"
                                          IsChecked="{Binding NewOrderIsOnlinePayment}"
                                          FontSize="15"
                                          Margin="0,6,0,6"/>
                                <TextBlock Text="{DynamicResource PaymentHint}"
                                           Style="{StaticResource InfoTextStyle}"
                                           Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource InnerCardStyle}"
                            Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ProblemPhotoLabel}"
                                       Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{DynamicResource ProblemPhotoHint}"
                                       Style="{StaticResource InfoTextStyle}"
                                       Margin="0,4,0,12"/>

                                <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                    <Button Content="{DynamicResource AddPhotoButton}"
                                        Command="{Binding SelectProblemPhotoCommand}"
                                        Style="{StaticResource MediumPrimaryButtonStyle}"
                                        Width="156"
                                        Margin="0,0,10,0"/>
                                    <Button Content="{DynamicResource RemovePhotoButton}"
                                        Command="{Binding RemoveProblemPhotoCommand}"
                                        Style="{StaticResource SmallSecondaryButtonStyle}"
                                        Width="118"
                                        Visibility="{Binding HasSelectedProblemPhoto, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding NewOrderProblemPhotoStatus}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,10"/>

                                <Border Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8"
                                    Visibility="{Binding HasSelectedProblemPhoto, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding NewOrderProblemPhoto, Converter={StaticResource ByteArrayToImageConverter}}"
                                       Height="150"
                                       Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource CommentLabel}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewOrderClientComment, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="84"
                             Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">
                            <Button Content="{DynamicResource SendOrderButton}"
                                Command="{Binding CreateOrderCommand}"
                                Style="{StaticResource MediumPrimaryButtonStyle}"
                                MinWidth="190"
                                Margin="0,0,10,0"/>
                            <Button Content="{DynamicResource CancelButton}"
                                Command="{Binding CancelCreateOrderFormCommand}"
                                Style="{StaticResource MediumSecondaryButtonStyle}"
                                Width="96"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
