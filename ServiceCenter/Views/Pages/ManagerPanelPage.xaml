<Page x:Class="ServiceCenter.Views.Pages.ManagerPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:ServiceCenter.ViewModels"
      xmlns:conv="clr-namespace:ServiceCenter.Converters"
      mc:Ignorable="d"
      Title="ManagerPanelPage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Page.DataContext>
        <vm:ServiceMasterPanelViewModel />
    </Page.DataContext>

    <Page.Resources>
        <conv:OrderStatusConverter x:Key="OrderStatusConverter" />
    </Page.Resources>

    <Grid Margin="14,16,14,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource ManagerPanelTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="{DynamicResource MasterOrdersTab}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0"
                          Grid.ColumnSpan="2"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource SearchOrdersLabel}"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding OrderSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,0,14,0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColumnNumber}" Binding="{Binding DisplayNumber}" Width="95"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnClient}" Binding="{Binding User.Name}" Width="1.1*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnDevice}" Binding="{Binding DeviceType}" Width="1.1*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnBrand}" Binding="{Binding DeviceBrand}" Width="1*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnModel}" Binding="{Binding DeviceModel}" Width="1*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnProblem}" Binding="{Binding ProblemDescription}" Width="2*"/>
                            <DataGridTemplateColumn Header="{DynamicResource ColumnStatus}" Width="1.25*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding Status}"
                                                        ContentTemplate="{StaticResource OrderStatusBadgeTemplate}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Border Style="{StaticResource CardStyle}"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource WorkWithOrderTitle}"
                                           Style="{StaticResource SectionTitleStyle}"
                                           FontSize="18"
                                           Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource SelectedOrderLabel}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedOrder.DisplayNumber, TargetNullValue={StaticResource NotSelectedFemale}}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource SelectedClientLabel}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedOrder.User.Name, TargetNullValue={StaticResource NotSelectedMale}}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource SelectedDeviceLabel}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedOrder.DeviceType, TargetNullValue={StaticResource NotSelectedNeutral}}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource ClientPhoneLabel}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedOrder.ContactPhone, TargetNullValue={StaticResource NotSpecifiedText}}"/>
                                </Grid>

                                <TextBlock Text="{DynamicResource ProblemDescriptionLabel}" Style="{StaticResource FieldLabelStyle}" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedOrder.ProblemDescription, TargetNullValue={StaticResource NotSelectedNeutral}}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="{DynamicResource ClientCommentLabel}" Style="{StaticResource FieldLabelStyle}" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedOrder.ClientComment, TargetNullValue={StaticResource NoCommentText}}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <StackPanel Margin="0,0,0,12"
                                            Visibility="{Binding SelectedOrder.HasProblemPhoto, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{DynamicResource ProblemPhotoLabel}"
                                               Style="{StaticResource FieldLabelStyle}"
                                               FontSize="14"/>
                                    <Border Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="8"
                                            Margin="0,6,0,0">
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip="{DynamicResource OpenImageHint}"
                                                Tag="{Binding SelectedOrder.ProblemPhoto}"
                                                Click="ProblemPhoto_Click">
                                            <Image Source="{Binding SelectedOrder.ProblemPhoto, Converter={StaticResource ByteArrayToImageConverter}}"
                                                   Height="100"
                                                   Stretch="Uniform"/>
                                        </Button>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{DynamicResource PartsCostLabel}" Style="{StaticResource FieldLabelStyle}" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedOrder.EstimatedPartsCost, StringFormat={}{0:N2} BYN}"
                                           Margin="0,0,0,8"/>

                                <TextBlock Text="{DynamicResource MasterWorkCostLabel}" Style="{StaticResource FieldLabelStyle}" FontSize="14"/>
                                <TextBox Text="{Binding SelectedOrderMasterWorkCost, UpdateSourceTrigger=LostFocus}"
                                         Margin="0,0,0,8"
                                         Height="30"/>

                                <TextBlock Text="{DynamicResource PreliminaryAmountLabel}" Style="{StaticResource FieldLabelStyle}" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedOrder.EstimatedRepairCost, StringFormat={}{0:N2} BYN}"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="{DynamicResource NewStatusLabel}" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding OrderStatuses}"
                                          SelectedItem="{Binding SelectedOrderStatus}"
                                          ItemTemplate="{StaticResource OrderStatusTemplate}"
                                          Margin="0,0,0,12" Height="30"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="{DynamicResource SaveButton}"
                                            Style="{StaticResource MediumPrimaryButtonStyle}"
                                            Command="{Binding UpdateOrderStatusCommand}"/>
                                    <Button Grid.Column="2"
                                            Content="{DynamicResource OpenWarehouseButton}"
                                            Style="{StaticResource MediumSecondaryButtonStyle}"
                                            Command="{Binding OpenWarehouseWindowCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource MaterialRequestsTab}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{DynamicResource MaterialRequestsTitle}"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource SearchOrderLabel}"
                                   Style="{StaticResource FieldLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding MaterialRequestSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                    </Grid>
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CurrentOrderWarehouseRequests}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColumnOrderNumberShort}" Binding="{Binding OrderDisplayNumber}" Width="0.9*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnMaterial}" Binding="{Binding RequestedItemName}" Width="2*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnCategory}" Binding="{Binding RequestedCategory}" Width="1.3*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnQuantity}" Binding="{Binding RequestedQuantity}" Width="0.7*"/>
                            <DataGridTextColumn Header="{DynamicResource ColumnStatus}" Binding="{Binding DisplayStatus}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
