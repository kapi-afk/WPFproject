<Window x:Class="ServiceCenter.Views.WarehouseRequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource MasterRequestsButton}"
        Height="520"
        Width="980"
        MinHeight="520"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource MasterRequestsButton}"
                   Style="{StaticResource PageTitleStyle}"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding WarehouseRequests}"
                  SelectedItem="{Binding SelectedWarehouseRequest}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource ColumnOrderNumberShort}" Binding="{Binding OrderDisplayNumber}" Width="0.8*"/>
                <DataGridTextColumn Header="{DynamicResource ColumnMaster}" Binding="{Binding Master.Name}" Width="1.1*"/>
                <DataGridTextColumn Header="{DynamicResource ColumnMaterial}" Binding="{Binding RequestedItemName}" Width="1.4*"/>
                <DataGridTextColumn Header="{DynamicResource ColumnCategory}" Binding="{Binding RequestedCategory}" Width="1.1*"/>
                <DataGridTextColumn Header="{DynamicResource ColumnQuantity}" Binding="{Binding RequestedQuantity}" Width="0.7*"/>
                <DataGridTextColumn Header="{DynamicResource ColumnStatus}" Binding="{Binding DisplayStatus}" Width="1*"/>
                <DataGridTemplateColumn Header="" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{DynamicResource ResolveWarehouseRequestButton}"
                                    Width="104"
                                    Height="30"
                                    Style="{StaticResource SmallPrimaryButtonStyle}"
                                    FontSize="12"
                                    HorizontalAlignment="Center"
                                    Command="{Binding DataContext.ResolveWarehouseRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
