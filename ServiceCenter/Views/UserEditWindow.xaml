<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ServiceCenter.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ServiceCenter.Converters"
        Title="{DynamicResource UserEditWindowTitle}"
        Height="500"
        Width="620"
        MinHeight="480"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisConverter x:Key="BoolToVis"/>
        <Style x:Key="ValidationTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="#C62828"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ValidationMessageStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4,-8,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{DynamicResource UserEditWindowTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       FontSize="22"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Visibility="{Binding IsSelectedUserClient, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource LastNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserLastName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ValidationTextBoxStyle}"
                                 Tag="{Binding HasSelectedUserLastNameError}"/>
                        <TextBlock Text="{Binding SelectedUserLastNameValidationMessage}"
                                   Style="{StaticResource ValidationMessageStyle}"
                                   Visibility="{Binding HasSelectedUserLastNameError, Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="{DynamicResource FirstNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserFirstName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ValidationTextBoxStyle}"
                                 Tag="{Binding HasSelectedUserFirstNameError}"/>
                        <TextBlock Text="{Binding SelectedUserFirstNameValidationMessage}"
                                   Style="{StaticResource ValidationMessageStyle}"
                                   Visibility="{Binding HasSelectedUserFirstNameError, Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="{DynamicResource MiddleNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserMiddleName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ValidationTextBoxStyle}"
                                 Tag="{Binding HasSelectedUserMiddleNameError}"/>
                        <TextBlock Text="{Binding SelectedUserMiddleNameValidationMessage}"
                                   Style="{StaticResource ValidationMessageStyle}"
                                   Visibility="{Binding HasSelectedUserMiddleNameError, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsSelectedUserNonClient, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource FirstNameLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ValidationTextBoxStyle}"
                                 Tag="{Binding HasSelectedUserNameError}"/>
                        <TextBlock Text="{Binding SelectedUserNameValidationMessage}"
                                   Style="{StaticResource ValidationMessageStyle}"
                                   Visibility="{Binding HasSelectedUserNameError, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource ColumnRole}" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableRoles}"
                              SelectedItem="{Binding SelectedUserRole}"
                              Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource UserRoleConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Visibility="{Binding IsSelectedUserClient, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource EmailLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding SelectedUserEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ValidationTextBoxStyle}"
                                 Tag="{Binding HasSelectedUserEmailError}"/>
                        <TextBlock Text="{Binding SelectedUserEmailValidationMessage}"
                                   Style="{StaticResource ValidationMessageStyle}"
                                   Visibility="{Binding HasSelectedUserEmailError, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource ColumnLogin}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding SelectedUserLogin, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             Style="{StaticResource ValidationTextBoxStyle}"
                             Tag="{Binding HasSelectedUserLoginError}"/>
                    <TextBlock Text="{Binding SelectedUserLoginValidationMessage}"
                               Style="{StaticResource ValidationMessageStyle}"
                               Visibility="{Binding HasSelectedUserLoginError, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Visibility="{Binding IsSelectedUserMaster, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource MasterSpecializationLabel}" Style="{StaticResource FieldLabelStyle}"/>
                        <CheckBox Content="{DynamicResource SpecializationLaptops}"
                                  IsChecked="{Binding SelectedUserSpecializesLaptops}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="{DynamicResource SpecializationComputers}"
                                  IsChecked="{Binding SelectedUserSpecializesComputers}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="{DynamicResource SpecializationOfficeEquipment}"
                                  IsChecked="{Binding SelectedUserSpecializesOfficeEquipment}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="{DynamicResource CancelButton}"
                        Style="{StaticResource MediumSecondaryButtonStyle}"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Content="{DynamicResource SaveButton}"
                        Style="{StaticResource MediumPrimaryButtonStyle}"
                        Width="150"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
