<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ServiceCenter.Views.AdminOrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource EditOrderTitle}"
        Height="620"
        Width="520"
        MinHeight="520"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="OrderFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="OrderValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{DynamicResource EditOrderTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       FontSize="22"/>

            <TextBlock Text="{DynamicResource ProblemDescriptionLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <TextBlock Text="{Binding SelectedOrder.ProblemDescription}"
                       Style="{StaticResource OrderValueTextStyle}"/>

            <TextBlock Text="{DynamicResource ClientCommentLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <TextBlock Text="{Binding SelectedOrder.ClientComment, TargetNullValue={StaticResource NoCommentText}}"
                       Style="{StaticResource OrderValueTextStyle}"/>

            <StackPanel Margin="0,0,0,12"
                        Visibility="{Binding SelectedOrder.HasProblemPhoto, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{DynamicResource ProblemPhotoLabel}"
                           Style="{StaticResource OrderFieldLabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Background="{DynamicResource InputBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Cursor="Hand"
                            ToolTip="{DynamicResource OpenImageHint}"
                            Tag="{Binding SelectedOrder.ProblemPhoto}"
                            Click="ProblemPhoto_Click">
                        <Image Source="{Binding SelectedOrder.ProblemPhoto, Converter={StaticResource ByteArrayToImageConverter}}"
                               Height="110"
                               Stretch="Uniform"/>
                    </Button>
                </Border>
            </StackPanel>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource ClientPhoneLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedOrder.ContactPhone}" Style="{StaticResource OrderValueTextStyle}"/>

                    <TextBlock Text="{DynamicResource DeliveryTypeLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedOrder.DeliveryMethodDisplay, TargetNullValue={StaticResource PickupText}}"
                               Style="{StaticResource OrderValueTextStyle}"/>

                    <TextBlock Text="{DynamicResource PaymentMethodLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedOrder.PaymentMethodDisplay}"
                               Style="{StaticResource OrderValueTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource ClientEmailLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedOrder.User.Email, TargetNullValue={StaticResource NotSpecifiedText}}"
                               Style="{StaticResource OrderValueTextStyle}"/>

                    <TextBlock Text="{DynamicResource CourierAddressAdminLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedOrder.DeliveryAddress, TargetNullValue={StaticResource NotRequiredText}}"
                               Style="{StaticResource OrderValueTextStyle}"/>

                    <TextBlock Text="{DynamicResource PaymentStatusLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedOrder.PaymentStatusText}"
                               Style="{StaticResource OrderValueTextStyle}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{DynamicResource OrderAmountsTitle}" Style="{StaticResource OrderFieldLabelStyle}"/>

            <TextBlock Text="{DynamicResource PartsCostLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <TextBlock Text="{Binding SelectedOrder.EstimatedPartsCost, StringFormat={}{0:N2} BYN}"
                       Style="{StaticResource OrderValueTextStyle}"/>

            <TextBlock Text="{DynamicResource MasterWorkCostLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <TextBlock Text="{Binding SelectedOrder.MasterWorkCost, StringFormat={}{0:N2} BYN}"
                       Style="{StaticResource OrderValueTextStyle}"/>

            <TextBlock Text="{DynamicResource PreliminaryAmountLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <TextBlock Text="{Binding SelectedOrder.EstimatedRepairCost, StringFormat={}{0:N2} BYN}"
                       Style="{StaticResource OrderValueTextStyle}"
                       FontWeight="SemiBold"/>

            <TextBlock Text="{DynamicResource AssignMasterLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <ComboBox ItemsSource="{Binding Masters}"
                      SelectedItem="{Binding SelectedMaster}"
                      DisplayMemberPath="Name"
                      TextSearch.TextPath="Name"
                      Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource OrderStatusLabel}" Style="{StaticResource OrderFieldLabelStyle}"/>
            <ComboBox ItemsSource="{Binding OrderStatuses}"
                      SelectedItem="{Binding SelectedOrderStatus}"
                      ItemTemplate="{StaticResource OrderStatusTemplate}"
                      Margin="0,0,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{DynamicResource SaveChangesButton}"
                        Click="Save_Click"/>
                <Button Grid.Column="2"
                        Content="{DynamicResource DeleteOrderButton}"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="Delete_Click"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
